# API Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Code Execution Backend
# Provider options: direct | judge0 | piston
#   - "direct"  → Runs code via child_process (best for Railway/VPS). Set this for Railway.
#   - "judge0"  → Uses Judge0 CE free public API (no setup, limited requests)
#   - "piston"  → Uses self-hosted Piston instance (see docker/piston/README.md)
CODE_EXECUTION_PROVIDER=direct

# Only needed for Piston or custom Judge0:
# CODE_EXECUTION_URL=http://localhost:2000/api/v2/execute

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id


# Piston Queue Configuration
PISTON_URL=https://maazopenclaw.centralindia.cloudapp.azure.com/api/v2/execute
PISTON_QUEUE_MAX_SHARED=3

# AI Interview voice — TTS resolution order in /api/ai-interview/tts:
#   1. Azure AI Speech (fast, ~sub-second, free tier 0.5M chars/mo) — PREFERRED
#   2. Self-hosted Kokoro on the Azure VM (KOKORO_TTS_URL)
#   3. In-process Kokoro (local dev only)
# AZURE_SPEECH_KEY=your_azure_speech_key
# AZURE_SPEECH_REGION=centralindia
# AZURE_SPEECH_VOICE=en-US-AriaNeural   # or en-IN-NeerjaNeural for Indian English

# KOKORO_TTS_URL=https://maazopenclaw.centralindia.cloudapp.azure.com:2001/tts
# KOKORO_TTS_SECRET=set-a-strong-shared-secret-and-match-it-on-the-service
# Speech-to-text (Whisper) — standalone service on the Azure VM (see docker/whisper-stt/)
# WHISPER_STT_URL=https://maazopenclaw.centralindia.cloudapp.azure.com:2002/stt
# WHISPER_STT_SECRET=set-a-strong-shared-secret-and-match-it-on-the-service

# AI provider — DeepSeek (OpenAI-compatible /chat/completions). Powers AI
# features (Resume Maker ATS scoring + writing assist, project evaluation) via
# an env fallback so they work without an admin saving a key in Firestore
# (appConfig/aiProvider). When an admin HAS saved a key there, it wins over
# this. Get a key at https://platform.deepseek.com.
# DEEPSEEK_API_KEY=sk-...

# Firebase Service Account (for seed scripts)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Redis (DigitalOcean Managed Redis/Valkey or self-hosted) — OPTIONAL.
# Powers the shared catalog cache (cuts Firestore reads across the whole fleet)
# and API rate limiting. If unset, the app falls back to per-instance caching
# and rate limiting is disabled (fail-open) — nothing breaks.
# DO Managed Redis uses TLS, so use the rediss:// connection string from the
# DO dashboard (Databases → your Redis → Connection details → "Public network"
# or VPC). Example:
# REDIS_URL=rediss://default:PASSWORD@db-redis-xxx.db.ondigitalocean.com:25061

# ── imgproxy (Heroku-hosted, Cloudflare-fronted) ──────────────────────────
# Public host of your imgproxy service. Set this and the lib/imgproxy.ts
# helper starts emitting optimized URLs (WebP/AVIF, resized, cached at
# Cloudflare). Leave unset locally to pass URLs through untouched.
# NEXT_PUBLIC_IMGPROXY_URL=https://img.placementranker.com
# Optional defense-in-depth: HMAC-sign every transform URL on the server.
# Generate 32 random bytes hex-encoded for each (e.g. `openssl rand -hex 32`).
# IMGPROXY_KEY=
# IMGPROXY_SALT=
# Optional: protect the /api/health/redis probe with a token.
# REDIS_HEALTH_TOKEN=some-long-random-string
