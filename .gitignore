# Dependencies
node_modules/
package-lock.json
yarn.lock

# Firebase service account key (sensitive!)
serviceAccountKey.json
*.key.json

# Environment variables
.env
.env.local
.env.*.local

# Vercel CLI (local project link + auth artifacts)
.vercel

# Logs
*.log
logs/
npm-debug.log*

# OS
.DS_Store
Thumbs.db

apps/web/.next/
apps/admin/.next/


# IDE
.vscode/
.idea/
*.swp
*.swo

# Firebase emulator snapshots + UI cache (local-only)
firebase/.emulator-data/
firebase/firebase-debug.log
firebase/firestore-debug.log
firebase/ui-debug.log
firebase/database-debug.log
firebase/auth-debug.log

# Third-party infra checkouts — these are independent git repos
# (Heroku deploy stubs) maintained out-of-band. Ignoring them keeps
# `git add .` clean and avoids accidentally committing them as
# embedded gitlinks.
infra/imgproxy/
infra/meilisearch/

# Turbo daemon + lock cookies — local build cache only.
.turbo/

# Deploy env files — VM-specific, may carry endpoints / tokens.
.deploy/*.env

# Local-only reference checkouts (open-source RN apps + design systems we study).
reference-libs/

# Abandoned TWA wrapper experiment (not the real app; apps/mobile is)
android-twa/
