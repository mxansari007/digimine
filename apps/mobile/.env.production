# Production device build — point the app at the live backend + real Firebase
# (not the local emulators in .env). EXPO_PUBLIC_* vars are inlined at bundle
# time, so a release build must be made with these set. Loaded by Expo in
# production mode and overrides .env.
EXPO_PUBLIC_API_URL=https://www.placementranker.com
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=0
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=775565039718-6oaejftukqr0s58kbsm57kjmgrjaokli.apps.googleusercontent.com
