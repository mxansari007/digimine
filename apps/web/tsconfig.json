{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@digimine/shared": [
                "../../packages/shared/src"
            ],
            "@digimine/shared/*": [
                "../../packages/shared/src/*"
            ],
            "@digimine/ui": [
                "../../packages/ui/src"
            ],
            "@digimine/ui/*": [
                "../../packages/ui/src/*"
            ],
            "@digimine/types": [
                "../../packages/types/src"
            ],
            "@digimine/types/*": [
                "../../packages/types/src/*"
            ],
            "@digimine/config": [
                "../../packages/config/src"
            ],
            "@digimine/config/*": [
                "../../packages/config/src/*"
            ],
            "@digimine/utils": [
                "../../packages/utils/src"
            ],
            "@digimine/utils/*": [
                "../../packages/utils/src/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/__tests__/**"
    ]
}