{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "declaration": true,
        "declarationMap": true,
        "composite": false,
        "paths": {
            "@digimine/ui": [
                "./packages/ui/src"
            ],
            "@digimine/ui/*": [
                "./packages/ui/src/*"
            ],
            "@digimine/types": [
                "./packages/types/src"
            ],
            "@digimine/types/*": [
                "./packages/types/src/*"
            ],
            "@digimine/config": [
                "./packages/config/src"
            ],
            "@digimine/config/*": [
                "./packages/config/src/*"
            ],
            "@digimine/utils": [
                "./packages/utils/src"
            ],
            "@digimine/utils/*": [
                "./packages/utils/src/*"
            ]
        }
    },
    "exclude": [
        "node_modules"
    ]
}